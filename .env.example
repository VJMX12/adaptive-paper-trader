# Telegram bot (create via @BotFather). Leave empty to run without Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: enables LLM-written reasoning & reviews when llm.enabled: true
ANTHROPIC_API_KEY=

# Bybit API keys — only needed for REAL orders (live.enabled: true in config).
# Create with TRADE (contract/unified) permission ONLY — NO withdrawal, no
# IP whitelist (Railway IPs are dynamic). Leave empty for dry-run.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Explicit arming: real orders are placed ONLY if this equals YES (in addition
# to keys + live.enabled). Provisioning keys alone will NOT go live.
LIVE_CONFIRM=

# Optional dashboard auth. If DASHBOARD_PASS is set, all dashboard routes
# require HTTP Basic Auth (user defaults to "admin"). Strongly recommended
# once live — the dashboard is on a public URL.
DASHBOARD_USER=
DASHBOARD_PASS=
